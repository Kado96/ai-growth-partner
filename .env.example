# 🚀 KORA AGENCY - CONFIG DE PRODUCTION

# --- SERVEUR & API ---
PORT=5001
NODE_ENV=production

# --- NOTIFICATIONS EMAIL (SMTP GMAIL) ---
# Allez sur votre compte Google > Sécurité > Mots de passe d'applications
EMAIL_USER=votre-email@gmail.com
EMAIL_PASS=votre-mot-de-passe-application

# --- ACCÈS ADMIN ---
ADMIN_USER=admin
ADMIN_PASS=votre-mot-de-passe-securise
JWT_SECRET=un-secret-tres-long-et-aleatoire

# --- SUPABASE (OPTIONNEL) ---
# Laissez vide si vous voulez utiliser le fichier config.json local
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- FRONTEND ---
VITE_API_URL=
